generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(100)
  address     String       @db.VarChar(255)
  lat         Decimal      @db.Decimal(10, 6)
  lng         Decimal      @db.Decimal(10, 6)
  phone       String?      @db.VarChar(20)
  email       String?      @db.VarChar(100)
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  bookings    Booking[]
  courts      Court[]
  orders      Order[]
  salesOrders SalesOrder[]
  warehouses  Warehouse[]

  @@map("branches")
}

model Warehouse {
  id                    Int                    @id @default(autoincrement())
  name                  String                 @unique @db.VarChar(100)
  branchId              Int?                   @map("branch_id")
  address               String?                @db.VarChar(255)
  isHub                 Boolean                @default(false) @map("is_hub")
  isActive              Boolean                @default(true) @map("is_active")
  createdAt             DateTime               @default(now()) @map("created_at")
  adminSlips            AdminWarehouseSlip[]
  inventory             Inventory[]
  inventoryTransactions InventoryTransaction[]
  purchaseOrders        PurchaseOrder[]
  transferFrom          TransferRequest[]      @relation("TransferFrom")
  transferTo            TransferRequest[]      @relation("TransferTo")
  users                 User[]
  branch                Branch?                @relation(fields: [branchId], references: [id])

  @@map("warehouses")
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  username            String               @unique @db.VarChar(50)
  passwordHash        String               @map("password_hash") @db.VarChar(255)
  fullName            String               @map("full_name") @db.VarChar(100)
  email               String               @unique @db.VarChar(100)
  phone               String               @unique @db.VarChar(15)
  address             String?              @db.VarChar(255)
  gender              Gender?
  dateOfBirth         DateTime?            @map("date_of_birth") @db.Date
  role                UserRole             @default(user)
  warehouseId         Int?                 @map("warehouse_id")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @default(now()) @updatedAt @map("updated_at")
  slipsAssigned       AdminWarehouseSlip[] @relation("SlipAssignedTo")
  slipsCreated        AdminWarehouseSlip[] @relation("SlipCreatedBy")
  slipsProcessed      AdminWarehouseSlip[] @relation("SlipProcessedBy")
  bookings            Booking[]
  fixedSchedules      FixedSchedule[]
  ordersApproved      Order[]              @relation("OrderApprovedBy")
  orders              Order[]
  purchaseOrders      PurchaseOrder[]
  reviews             Review[]
  salesOrdersApproved SalesOrder[]         @relation("SalesApprovedBy")
  salesOrdersCreated  SalesOrder[]         @relation("SalesCreatedBy")
  transfersApproved   TransferRequest[]    @relation("TransferApprovedBy")
  transfersCreated    TransferRequest[]    @relation("TransferCreatedBy")
  warehouse           Warehouse?           @relation(fields: [warehouseId], references: [id])

  @@map("users")
}

model Court {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar(100)
  branchId     Int            @map("branch_id")
  type         CourtType      @default(standard)
  indoor       Boolean        @default(true)
  price        Decimal        @db.Decimal(12, 0)
  rating       Decimal        @default(0) @db.Decimal(2, 1)
  reviewsCount Int            @default(0) @map("reviews_count")
  image        String?        @db.VarChar(255)
  description  String?
  hours        String?        @default("06:00 - 22:00") @db.VarChar(20)
  available    Boolean        @default(true)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at")
  bookings     Booking[]
  fixedSchedules FixedSchedule[]
  fixedOccurrences FixedScheduleOccurrence[]
  amenities    CourtAmenity[]
  slots        CourtSlot[]
  branch       Branch         @relation(fields: [branchId], references: [id])
  reviews      Review[]

  @@map("courts")
}

model CourtAmenity {
  id      Int    @id @default(autoincrement())
  courtId Int    @map("court_id")
  amenity String @db.VarChar(50)
  court   Court  @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@map("court_amenities")
}

model Supplier {
  id             Int                  @id @default(autoincrement())
  name           String               @db.VarChar(100)
  contactPerson  String?              @map("contact_person") @db.VarChar(100)
  phone          String?              @db.VarChar(20)
  email          String?              @db.VarChar(100)
  address        String?              @db.VarChar(255)
  isActive       Boolean              @default(true) @map("is_active")
  createdAt      DateTime             @default(now()) @map("created_at")
  adminSlips     AdminWarehouseSlip[]
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model Product {
  id              Int              @id @default(autoincrement())
  sku             String           @unique @db.VarChar(20)
  name            String           @db.VarChar(200)
  brand           String           @db.VarChar(50)
  category        String           @db.VarChar(50)
  price           Decimal          @db.Decimal(12, 0)
  originalPrice   Decimal?         @map("original_price") @db.Decimal(12, 0)
  rating          Decimal          @default(0) @db.Decimal(2, 1)
  reviewsCount    Int              @default(0) @map("reviews_count")
  image           String?          @db.VarChar(255)
  description     String?
  specs           Json?
  features        Json?
  inStock         Boolean          @default(true) @map("in_stock")
  gender          Gender?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at")
  inventory       Inventory[]
  orderItems      OrderItem[]
  badges          ProductBadge[]
  images          ProductImage[]
  salesOrderItems SalesOrderItem[]

  @@map("products")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  url       String  @db.VarChar(255)
  sortOrder Int     @default(0) @map("sort_order")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductBadge {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  badge     String  @db.VarChar(20)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_badges")
}

model Booking {
  id            String        @id @default(uuid()) @db.Uuid
  courtId       Int           @map("court_id")
  branchId      Int           @map("branch_id")
  userId        String?       @map("user_id") @db.Uuid
  bookingDate   DateTime      @map("booking_date") @db.Date
  dayLabel      String        @map("day_label") @db.VarChar(10)
  timeStart     String        @map("time_start") @db.VarChar(5)
  timeEnd       String?       @map("time_end") @db.VarChar(5)
  people        Int           @default(2)
  amount        Decimal       @db.Decimal(12, 0)
  pricePerHour  Decimal       @default(0) @map("price_per_hour") @db.Decimal(12, 0)
  status        BookingStatus @default(pending)
  fixedScheduleId String?     @map("fixed_schedule_id") @db.Uuid
  fixedOccurrenceId String?   @unique @map("fixed_occurrence_id") @db.Uuid
  paymentMethod String        @map("payment_method") @db.VarChar(30)
  customerName  String        @map("customer_name") @db.VarChar(100)
  customerPhone String        @map("customer_phone") @db.VarChar(15)
  customerEmail String?       @map("customer_email") @db.VarChar(100)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at")
  branch        Branch        @relation(fields: [branchId], references: [id])
  court         Court         @relation(fields: [courtId], references: [id])
  fixedSchedule FixedSchedule? @relation(fields: [fixedScheduleId], references: [id])
  fixedOccurrence FixedScheduleOccurrence? @relation(fields: [fixedOccurrenceId], references: [id])
  user          User?         @relation(fields: [userId], references: [id])
  slots         CourtSlot[]
  invoices      Invoice[]

  @@index([courtId, bookingDate], map: "idx_bookings_court_date")
  @@index([status], map: "idx_bookings_status")
  @@index([customerPhone], map: "idx_bookings_phone")
  @@map("bookings")
}

model FixedSchedule {
  id                    String                    @id @default(uuid()) @db.Uuid
  userId                String?                   @map("user_id") @db.Uuid
  courtId               Int                       @map("court_id")
  cycle                 FixedScheduleCycle
  startDate             DateTime                  @map("start_date") @db.Date
  endDate               DateTime                  @map("end_date") @db.Date
  timeStart             String                    @map("time_start") @db.VarChar(5)
  timeEnd               String                    @map("time_end") @db.VarChar(5)
  customerName          String                    @map("customer_name") @db.VarChar(100)
  customerPhone         String                    @map("customer_phone") @db.VarChar(15)
  customerEmail         String?                   @map("customer_email") @db.VarChar(100)
  paymentMethod         String                    @map("payment_method") @db.VarChar(30)
  pricePerHourSnapshot  Decimal                   @map("price_per_hour_snapshot") @db.Decimal(12, 0)
  totalAmountSnapshot   Decimal                   @map("total_amount_snapshot") @db.Decimal(12, 0)
  occurrenceCount       Int                       @default(0) @map("occurrence_count")
  adjustmentLimit       Int                       @default(2) @map("adjustment_limit")
  adjustmentUsed        Int                       @default(0) @map("adjustment_used")
  status                FixedScheduleStatus       @default(pending)
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @default(now()) @updatedAt @map("updated_at")
  bookings              Booking[]
  court                 Court                     @relation(fields: [courtId], references: [id])
  user                  User?                     @relation(fields: [userId], references: [id])
  occurrences           FixedScheduleOccurrence[]
  adjustments           FixedScheduleAdjustment[]
  invoices              Invoice[]

  @@index([userId], map: "idx_fixed_schedules_user")
  @@index([status], map: "idx_fixed_schedules_status")
  @@map("fixed_schedules")
}

model FixedScheduleOccurrence {
  id                    String                    @id @default(uuid()) @db.Uuid
  fixedScheduleId       String                    @map("fixed_schedule_id") @db.Uuid
  courtId               Int                       @map("court_id")
  occurrenceDate        DateTime                  @map("occurrence_date") @db.Date
  dayLabel              String                    @map("day_label") @db.VarChar(10)  // ✨ THÊM DÒNG NÀY
  timeStart             String                    @map("time_start") @db.VarChar(5)
  timeEnd               String                    @map("time_end") @db.VarChar(5)
  pricePerHourSnapshot  Decimal                   @map("price_per_hour_snapshot") @db.Decimal(12, 0)
  amountSnapshot        Decimal                   @map("amount_snapshot") @db.Decimal(12, 0)
  status                FixedOccurrenceStatus     @default(scheduled)
  booking               Booking?
  court                 Court                     @relation(fields: [courtId], references: [id])
  fixedSchedule         FixedSchedule             @relation(fields: [fixedScheduleId], references: [id], onDelete: Cascade)
  adjustments           FixedScheduleAdjustment[]

  @@map("fixed_schedule_occurrences")
}

model FixedScheduleAdjustment {
  id                    String                    @id @default(uuid()) @db.Uuid
  fixedScheduleId       String                    @map("fixed_schedule_id") @db.Uuid
  occurrenceId          String?                   @map("occurrence_id") @db.Uuid
  type                  FixedAdjustmentType
  oldCourtId            Int?                      @map("old_court_id")
  oldDate               DateTime?                 @map("old_date") @db.Date
  oldTimeStart          String?                   @map("old_time_start") @db.VarChar(5)
  oldTimeEnd            String?                   @map("old_time_end") @db.VarChar(5)
  newCourtId            Int?                      @map("new_court_id")
  newDate               DateTime?                 @map("new_date") @db.Date
  newTimeStart          String?                   @map("new_time_start") @db.VarChar(5)
  newTimeEnd            String?                   @map("new_time_end") @db.VarChar(5)
  note                  String?
  createdAt             DateTime                  @default(now()) @map("created_at")
  fixedSchedule         FixedSchedule             @relation(fields: [fixedScheduleId], references: [id], onDelete: Cascade)
  occurrence            FixedScheduleOccurrence?  @relation(fields: [occurrenceId], references: [id])

  @@index([fixedScheduleId], map: "idx_fixed_adjustments_schedule")
  @@map("fixed_schedule_adjustments")
}

model Invoice {
  id                    String                    @id @default(uuid()) @db.Uuid
  code                  String                    @unique @db.VarChar(30)
  bookingId             String?                   @map("booking_id") @db.Uuid
  orderId               String?                   @map("order_id") @db.Uuid
  fixedScheduleId       String?                   @map("fixed_schedule_id") @db.Uuid
  customerName          String                    @map("customer_name") @db.VarChar(100)
  customerPhone         String                    @map("customer_phone") @db.VarChar(15)
  customerEmail         String?                   @map("customer_email") @db.VarChar(100)
  subtotalSnapshot      Decimal                   @map("subtotal_snapshot") @db.Decimal(12, 0)
  totalSnapshot         Decimal                   @map("total_snapshot") @db.Decimal(12, 0)
  paymentMethod         String                    @map("payment_method") @db.VarChar(30)
  status                InvoiceStatus             @default(unpaid)
  createdAt             DateTime                  @default(now()) @map("created_at")
  booking               Booking?                  @relation(fields: [bookingId], references: [id])
  fixedSchedule         FixedSchedule?            @relation(fields: [fixedScheduleId], references: [id])
  order                 Order?                    @relation(fields: [orderId], references: [id])
  items                 InvoiceItem[]

  @@index([bookingId], map: "idx_invoices_booking")
  @@index([fixedScheduleId], map: "idx_invoices_fixed_schedule")
  @@map("invoices")
}

model InvoiceItem {
  id                    Int                       @id @default(autoincrement())
  invoiceId             String                    @map("invoice_id") @db.Uuid
  description           String                    @db.VarChar(255)
  quantity              Int
  unitPriceSnapshot     Decimal                   @map("unit_price_snapshot") @db.Decimal(12, 0)
  lineTotalSnapshot     Decimal                   @map("line_total_snapshot") @db.Decimal(12, 0)
  invoice               Invoice                   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model CourtSlot {
  id        Int             @id @default(autoincrement())
  courtId   Int             @map("court_id")
  slotDate  DateTime        @map("slot_date") @db.Date
  dateLabel String          @map("date_label") @db.VarChar(10)
  time      String          @db.VarChar(5)
  status    CourtSlotStatus @default(booked)
  bookedBy  String?         @map("booked_by") @db.VarChar(100)
  phone     String?         @db.VarChar(15)
  bookingId String?         @map("booking_id") @db.Uuid
  createdAt DateTime        @default(now()) @map("created_at")
  booking   Booking?        @relation(fields: [bookingId], references: [id])
  court     Court           @relation(fields: [courtId], references: [id])

  @@unique([courtId, slotDate, time])
  @@index([courtId, slotDate], map: "idx_court_slots_lookup")
  @@map("court_slots")
}

model Order {
  id                    String         @id @default(uuid()) @db.Uuid
  userId                String?        @map("user_id") @db.Uuid
  type                  OrderType      @default(online)
  deliveryMethod        DeliveryMethod @default(delivery) @map("delivery_method")
  pickupBranchId        Int?           @map("pickup_branch_id")
  fulfillingWarehouseId Int?           @map("fulfilling_warehouse_id")
  customerCoords        Json?          @map("customer_coords")
  customerName          String         @map("customer_name") @db.VarChar(100)
  customerPhone         String         @map("customer_phone") @db.VarChar(15)
  customerEmail         String?        @map("customer_email") @db.VarChar(100)
  customerAddress       String?        @map("customer_address") @db.VarChar(255)
  note                  String?
  subtotal              Decimal        @db.Decimal(12, 0)
  shippingFee           Decimal        @default(0) @map("shipping_fee") @db.Decimal(12, 0)
  total                 Decimal        @db.Decimal(12, 0)
  paymentMethod         String         @map("payment_method") @db.VarChar(30)
  status                OrderStatus    @default(pending)
  approvedBy            String?        @map("approved_by") @db.Uuid
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @default(now()) @updatedAt @map("updated_at")
  items                 OrderItem[]
  invoices             Invoice[]
  approver              User?          @relation("OrderApprovedBy", fields: [approvedBy], references: [id])
  pickupBranch          Branch?        @relation(fields: [pickupBranchId], references: [id])
  user                  User?          @relation(fields: [userId], references: [id])

  @@index([status], map: "idx_orders_status")
  @@index([userId], map: "idx_orders_user")
  @@index([createdAt], map: "idx_orders_created")
  @@map("orders")
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     String  @map("order_id") @db.Uuid
  productId   Int     @map("product_id")
  productName String  @map("product_name") @db.VarChar(200)
  price       Decimal @db.Decimal(12, 0)
  qty         Int
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model SalesOrder {
  id            String              @id @default(uuid()) @db.Uuid
  createdBy     String              @map("created_by") @db.Uuid
  branchId      Int?                @map("branch_id")
  customerName  String              @map("customer_name") @db.VarChar(100)
  customerPhone String?             @map("customer_phone") @db.VarChar(15)
  total         Decimal             @db.Decimal(12, 0)
  discount      Decimal             @default(0) @db.Decimal(12, 0)
  finalTotal    Decimal             @map("final_total") @db.Decimal(12, 0)
  paymentMethod String              @map("payment_method") @db.VarChar(30)
  note          String?
  status        SalesOrderStatus    @default(pending)
  approvedBy    String?             @map("approved_by") @db.Uuid
  approvedAt    DateTime?           @map("approved_at")
  rejectReason  String?             @map("reject_reason") @db.VarChar(255)
  exportSlipId  String?             @map("export_slip_id") @db.Uuid
  createdAt     DateTime            @default(now()) @map("created_at")
  items         SalesOrderItem[]
  approver      User?               @relation("SalesApprovedBy", fields: [approvedBy], references: [id])
  branch        Branch?             @relation(fields: [branchId], references: [id])
  creator       User                @relation("SalesCreatedBy", fields: [createdBy], references: [id])
  exportSlip    AdminWarehouseSlip? @relation(fields: [exportSlipId], references: [id])

  @@index([status], map: "idx_sales_orders_status")
  @@map("sales_orders")
}

model SalesOrderItem {
  id           Int        @id @default(autoincrement())
  salesOrderId String     @map("sales_order_id") @db.Uuid
  productId    Int        @map("product_id")
  productName  String     @map("product_name") @db.VarChar(200)
  price        Decimal    @db.Decimal(12, 0)
  qty          Int
  product      Product    @relation(fields: [productId], references: [id])
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@map("sales_order_items")
}

model Inventory {
  id           Int       @id @default(autoincrement())
  sku          String    @db.VarChar(20)
  productId    Int?      @map("product_id")
  warehouseId  Int       @map("warehouse_id")
  name         String    @db.VarChar(200)
  category     String    @db.VarChar(50)
  onHand       Int       @default(0) @map("on_hand")
  reserved     Int       @default(0)
  available    Int       @default(0)
  reorderPoint Int       @default(0) @map("reorder_point")
  unitCost     Decimal   @map("unit_cost") @db.Decimal(12, 0)
  image        String?   @db.VarChar(255)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  product      Product?  @relation(fields: [productId], references: [id])
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([sku, warehouseId])
  @@index([warehouseId], map: "idx_inventory_warehouse")
  @@index([sku], map: "idx_inventory_sku")
  @@map("inventory")
}

model InventoryTransaction {
  id          String          @id @default(uuid()) @db.Uuid
  type        TransactionType
  date        DateTime
  sku         String          @db.VarChar(20)
  warehouseId Int             @map("warehouse_id")
  qty         Int
  cost        Decimal         @db.Decimal(12, 0)
  note        String?
  operatorId  String?         @map("operator_id") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at")
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id])

  @@index([warehouseId, date], map: "idx_txn_warehouse_date")
  @@index([sku], map: "idx_txn_sku")
  @@map("inventory_transactions")
}

model TransferRequest {
  id              String         @id @default(uuid()) @db.Uuid
  date            DateTime
  fromWarehouseId Int            @map("from_warehouse_id")
  toWarehouseId   Int            @map("to_warehouse_id")
  reason          String         @db.VarChar(255)
  note            String?
  status          TransferStatus @default(pending)
  pickupMethod    PickupMethod   @map("pickup_method")
  createdBy       String         @map("created_by") @db.Uuid
  customerName    String?        @map("customer_name") @db.VarChar(100)
  customerPhone   String?        @map("customer_phone") @db.VarChar(15)
  approvedBy      String?        @map("approved_by") @db.Uuid
  approvedAt      DateTime?      @map("approved_at")
  completedAt     DateTime?      @map("completed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  items           TransferItem[]
  approver        User?          @relation("TransferApprovedBy", fields: [approvedBy], references: [id])
  creator         User           @relation("TransferCreatedBy", fields: [createdBy], references: [id])
  fromWarehouse   Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])

  @@index([status], map: "idx_transfer_status")
  @@map("transfer_requests")
}

model TransferItem {
  id                 Int             @id @default(autoincrement())
  transferId         String          @map("transfer_id") @db.Uuid
  sku                String          @db.VarChar(20)
  name               String          @db.VarChar(200)
  qty                Int
  availableAtRequest Int             @map("available_at_request")
  transfer           TransferRequest @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@map("transfer_items")
}

model PurchaseOrder {
  id          String               @id @default(uuid()) @db.Uuid
  supplierId  Int                  @map("supplier_id")
  warehouseId Int                  @map("warehouse_id")
  status      PurchaseOrderStatus  @default(draft)
  totalValue  Decimal              @map("total_value") @db.Decimal(14, 0)
  note        String?
  createdBy   String               @map("created_by") @db.Uuid
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @default(now()) @updatedAt @map("updated_at")
  slips       AdminWarehouseSlip[]
  items       PoItem[]
  creator     User                 @relation(fields: [createdBy], references: [id])
  supplier    Supplier             @relation(fields: [supplierId], references: [id])
  warehouse   Warehouse            @relation(fields: [warehouseId], references: [id])

  @@index([status], map: "idx_po_status")
  @@map("purchase_orders")
}

model PoItem {
  id            Int           @id @default(autoincrement())
  poId          String        @map("po_id") @db.Uuid
  sku           String        @db.VarChar(20)
  name          String        @db.VarChar(200)
  qty           Int
  unitCost      Decimal       @map("unit_cost") @db.Decimal(12, 0)
  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@map("po_items")
}

model AdminWarehouseSlip {
  id            String         @id @default(uuid()) @db.Uuid
  type          SlipType
  poId          String?        @map("po_id") @db.Uuid
  supplierId    Int?           @map("supplier_id")
  warehouseId   Int            @map("warehouse_id")
  note          String?
  status        SlipStatus     @default(pending)
  createdBy     String         @map("created_by") @db.Uuid
  assignedTo    String         @map("assigned_to") @db.Uuid
  processedAt   DateTime?      @map("processed_at")
  processedBy   String?        @map("processed_by") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at")
  assignee      User           @relation("SlipAssignedTo", fields: [assignedTo], references: [id])
  creator       User           @relation("SlipCreatedBy", fields: [createdBy], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [poId], references: [id])
  processor     User?          @relation("SlipProcessedBy", fields: [processedBy], references: [id])
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  salesOrders   SalesOrder[]
  items         SlipItem[]

  @@index([status], map: "idx_slips_status")
  @@map("admin_warehouse_slips")
}

model SlipItem {
  id       Int                @id @default(autoincrement())
  slipId   String             @map("slip_id") @db.Uuid
  sku      String             @db.VarChar(20)
  name     String             @db.VarChar(200)
  qty      Int
  unitCost Decimal            @map("unit_cost") @db.Decimal(12, 0)
  slip     AdminWarehouseSlip @relation(fields: [slipId], references: [id], onDelete: Cascade)

  @@map("slip_items")
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id") @db.Uuid
  courtId   Int      @map("court_id")
  rating    Int
  content   String?
  createdAt DateTime @default(now()) @map("created_at")
  court     Court    @relation(fields: [courtId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, courtId])
  @@map("reviews")
}

